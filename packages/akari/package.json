{
  "name": "akari",
  "version": "0.0.1",
  "description": "Main entry point and CLI for the Akari framework",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "akari": "./bin.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --build"
  },
  "dependencies": {
    "@akari/plugin-console": "workspace:*",
    "@akari/plugin-console-editor": "workspace:*",
    "@akari/plugin-console-explorer": "workspace:*",
    "@akari/plugin-console-market": "workspace:*",
    "@akari/core": "workspace:*",
    "@akari/plugin-content": "workspace:*",
    "@akari/plugin-engine-nunjucks": "workspace:*",
    "@akari/plugin-hmr": "workspace:*",
    "@akari/plugin-rss": "workspace:*",
    "@akari/plugin-server": "workspace:*",
    "@akari/plugin-sitemap": "workspace:*",
    "@akari/plugin-source-fs": "workspace:*",
    "@akari/plugin-theme-default": "workspace:*",
    "@akari/plugin-transformer-markdown": "workspace:*",
    "@minatojs/driver-memory": "^3.7.0",
    "cac": "^7.0.0",
    "cordis": "^3.18.1",
    "dotenv": "^17.2.3",
    "js-yaml": "^4.1.1",
    "minato": "^3.7.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.14.2",
    "typescript": "^5.4.5"
  }
}
