<!DOCTYPE html>
<html lang="{{ config.language or 'en' }}">
<head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>{{ config.title or 'Akari Blog' }}</title><link rel="stylesheet" href="/css/style.css"></head>
<body class="index-template">
<header class="site-header"><div class="container"><a href="/" class="site-title">{{ config.title or 'Akari Blog' }}</a><nav class="site-nav"><a href="/">Home</a><a href="/archives/">Archives</a><a href="/tags/">Tags</a></nav></div></header>
<main class="site-main container">
<div class="post-list">
  {% for post in posts %}
  <article class="post-card">
    <h2 class="post-card-title"><a href="{{ post.url }}">{{ post.title }}</a></h2>
    <time class="post-card-date" datetime="{{ isodate(post.date) }}">{{ formatDate(post.date) }}</time>
    {% if post.excerpt %}<p class="post-card-excerpt">{{ post.excerpt }}</p>{% endif %}
    {% if post.tags and post.tags.length %}
    <div class="post-card-tags">{% for tag in post.tags %}<a href="/tags/{{ tag | lower | replace(' ', '-') }}/" class="tag">{{ tag }}</a>{% endfor %}</div>
    {% endif %}
  </article>
  {% endfor %}
</div>
{% if pagination.total > 1 %}
<nav class="pagination">
  {% if pagination.prev %}<a href="{{ pagination.prev }}" class="prev">&laquo; Prev</a>{% endif %}
  <span class="page-number">Page {{ pagination.current }} of {{ pagination.total }}</span>
  {% if pagination.next %}<a href="{{ pagination.next }}" class="next">Next &raquo;</a>{% endif %}
</nav>
{% endif %}
</main>
<footer class="site-footer"><div class="container"><p>Powered by <a href="https://github.com/Mahoo12138/akari">Akari</a></p></div></footer>
</body></html>
