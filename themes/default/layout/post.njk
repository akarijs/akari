<!DOCTYPE html>
<html lang="{{ config.language or 'en' }}">
<head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>{{ post.title }} | {{ config.title or 'Akari Blog' }}</title><link rel="stylesheet" href="/css/style.css"></head>
<body class="post-template">
<header class="site-header"><div class="container"><a href="/" class="site-title">{{ config.title or 'Akari Blog' }}</a><nav class="site-nav"><a href="/">Home</a><a href="/archives/">Archives</a><a href="/tags/">Tags</a></nav></div></header>
<main class="site-main container">
<article class="post" id="post-{{ post.slug }}">
  <header class="post-header">
    <h1 class="post-title">{{ post.title }}</h1>
    <div class="post-meta"><time datetime="{{ isodate(post.date) }}">{{ formatDate(post.date) }}</time>{% if post.author %}<span class="post-author">by {{ post.author }}</span>{% endif %}</div>
    {% if post.tags and post.tags.length %}<div class="post-tags">{% for tag in post.tags %}<a href="/tags/{{ tag | lower | replace(' ', '-') }}/" class="tag">{{ tag }}</a>{% endfor %}</div>{% endif %}
  </header>
  <div class="post-content">{{ post.html | safe }}</div>
  <nav class="post-navigation">
    {% if prev_post %}<a href="{{ prev_post.url }}" class="prev-post">&laquo; {{ prev_post.title }}</a>{% endif %}
    {% if next_post %}<a href="{{ next_post.url }}" class="next-post">{{ next_post.title }} &raquo;</a>{% endif %}
  </nav>
</article>
</main>
<footer class="site-footer"><div class="container"><p>Powered by <a href="https://github.com/Mahoo12138/akari">Akari</a></p></div></footer>
</body></html>
